canvas "hello-world" {
    width  = 400
    height = 300
    background = #FFFFFF
}

frame main {
    width   = fill
    height  = fill
    layout  = vertical
    align   = center
    justify = center
    gap     = 16

    text "Hello, Pastel!" {
        size   = 32
        weight = bold
        color  = #111111
    }

    text "Design as Code" {
        size  = 16
        color = #666666
    }
}
